<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AlienStories.Views"
        xmlns:viewModels="clr-namespace:AlienStories.ViewModels"
        xmlns:models="clr-namespace:AlienStories.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="AlienStories.Views.MainWindow"
        Title="🌟 Звёздный приют"
        Width="900" Height="700"
        Background="#0a0a1a">

	<Design.DataContext>
		<viewModels:MainWindowViewModel />
	</Design.DataContext>

	<DockPanel>
		<!-- Верхняя панель -->
		<Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="15" CornerRadius="0 0 15 15">
			<DockPanel>
				<TextBlock Text="🌟 Звёздный приют" FontSize="24" FontWeight="Bold" Foreground="Gold" />

				<StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="20">
					<Button Content="🏠 Главная"
                            Command="{Binding SwitchToGameCommand}"
                            Background="#4a6fa5"
                            Foreground="White" />
					<Button Content="📚 Коллекция"
                            Command="{Binding SwitchToCollectionCommand}"
                            Background="#2a2a3e"
                            Foreground="White" />

					<TextBlock Text="|" Foreground="#444" />
					<TextBlock Text="{Binding FriendsLimitText}" FontSize="16" Foreground="#FFD700" FontWeight="Bold" />
					<TextBlock Text="|" Foreground="#444" />
					<TextBlock Text="{Binding FriendsCount}" FontSize="20" Foreground="White" />
					<TextBlock Text="друзей" FontSize="16" Foreground="#888" />
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- Контент -->
		<Grid Margin="20">
			<!-- Главный экран -->
			<Border x:Name="GamePanel" Background="#0a0a1a" CornerRadius="15"
                    IsVisible="{Binding IsGameActive}">
				<DockPanel>
					<Border DockPanel.Dock="Bottom" Background="#1a1a2e" Padding="10" CornerRadius="10" Margin="0,10,0,0">
						<TextBlock Text="{Binding GameStatusText}" FontSize="14" Foreground="#ccc" TextAlignment="Center" />
					</Border>
					<Canvas x:Name="GameCanvas" Background="Transparent" ClipToBounds="True" Width="800" Height="500" />
				</DockPanel>
			</Border>

			<!-- Экран коллекции -->
			<Border x:Name="CollectionPanel" Background="#0a0a1a" CornerRadius="15"
                    IsVisible="{Binding IsCollectionActive}">
				<ScrollViewer>
					<ItemsControl x:Name="CollectionItems" ItemsSource="{Binding CapturedCreatures}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:CapturedCreature">
								<Border Background="#1a1a2e" CornerRadius="10" Padding="15" Margin="10" Width="200">
									<StackPanel>
										<!-- Котик -->
										<views:AlienCatControl x:Name="CatControl" Width="80" Height="80"
                                                               Color="{Binding Catalog.ColorHex}"
                                                               IsHappy="True" />

										<TextBlock Text="{Binding Nickname}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Center" />
										<TextBlock Text="{Binding Catalog.Name}" FontSize="12" Foreground="#888" TextAlignment="Center" />

										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
											<TextBlock Text="❤️ " Foreground="Pink" />
											<TextBlock Text="{Binding TimesHugged}" Foreground="White" />
										</StackPanel>

										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
											<TextBlock Text="🍽️ " Foreground="Orange" />
											<TextBlock Text="{Binding TimesFed}" Foreground="White" />
										</StackPanel>

										<!-- Шкала сытости -->
										<Grid Margin="0,5,0,0">
											<Rectangle Height="8" RadiusX="4" RadiusY="4" Fill="#333" />
											<Rectangle Height="8" RadiusX="4" RadiusY="4"
                                                       Fill="LightGreen"
                                                       Width="{Binding Hunger}" />
										</Grid>

										<!-- Кнопки активностей -->
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0" Spacing="5">
											<Button Content="🤗" Command="{Binding $parent[Window].DataContext.HugCommand}"
                                                    CommandParameter="{Binding}" Width="35" Height="35" />
											<Button Content="🍎" Command="{Binding $parent[Window].DataContext.FeedCommand}"
                                                    CommandParameter="{Binding}" Width="35" Height="35" />
											<Button Content="📖" Command="{Binding $parent[Window].DataContext.StoryCommand}"
                                                    CommandParameter="{Binding}" Width="35" Height="35" />
											<Button Content="🕊️" Command="{Binding $parent[Window].DataContext.ReleaseCommand}"
                                                    CommandParameter="{Binding}" Width="35" Height="35"
                                                    Background="#e74c3c" Foreground="White" />
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Border>
		</Grid>
	</DockPanel>
</Window>