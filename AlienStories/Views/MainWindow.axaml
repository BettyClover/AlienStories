<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AlienStories.Views"
        xmlns:viewModels="clr-namespace:AlienStories.ViewModels"
        xmlns:models="clr-namespace:AlienStories.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="AlienStories.Views.MainWindow"
        Title="🌟 Звёздный приют"
        Width="900" Height="700"
        Background="#0a0a1a">

	<Design.DataContext>
		<viewModels:MainWindowViewModel />
	</Design.DataContext>

	<DockPanel>
		<Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="15" CornerRadius="0 0 15 15">
			<DockPanel>
				<TextBlock Text="🌟 Звёздный приют" FontSize="24" FontWeight="Bold" Foreground="Gold" />

				<StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="20">
					<Button Content="🏠 Главная" 
							Command="{Binding SwitchToGameCommand}" 
							Background="#4a6fa5" 
							Foreground="White" />
					<Button Content="📚 Коллекция" 
							Command="{Binding SwitchToCollectionCommand}" 
							Background="#2a2a3e" 
							Foreground="White" />
					<Button Content="📖 Альбом" 
							Command="{Binding SwitchToAlbumCommand}" 
							Background="#2a2a3e" 
							Foreground="White" />
					<Button Content="🌟 Звёздная охота"
						Command="{Binding SwitchToStarCatchCommand}"
						Background="#4a6fa5"
						Foreground="White" />
					<Button Content="🧠 Память"
						Command="{Binding SwitchToMemoryCommand}"
						Background="#2a2a3e"
						Foreground="White" />

					<TextBlock Text="|" Foreground="#444" />
					<TextBlock Text="{Binding StarDustText}" FontSize="18" Foreground="Gold" FontWeight="Bold" />
					<TextBlock Text="|" Foreground="#444" />
					<TextBlock Text="{Binding FriendsLimitText}" FontSize="16" Foreground="#FFD700" FontWeight="Bold" />
					<TextBlock Text="|" Foreground="#444" />
					<TextBlock Text="{Binding FriendsCount}" FontSize="20" Foreground="White" />
					<TextBlock Text="друзей" FontSize="16" Foreground="#888" />

					<Button Content="🌟 Супер-кормёжка (20 ✨)"
                            Command="{Binding SuperFeedCommand}"
                            Background="#FFD700"
                            Foreground="#1a1a2e"
                            FontWeight="Bold" />
				</StackPanel>
			</DockPanel>
		</Border>

		<Grid Margin="20">
			<Border x:Name="GamePanel" Background="#0a0a1a" CornerRadius="15"
					IsVisible="{Binding IsGameActive}">
				<DockPanel>
					<Border DockPanel.Dock="Bottom" Background="#1a1a2e" Padding="10" CornerRadius="10" Margin="0,10,0,0">
						<TextBlock Text="{Binding GameStatusText}" FontSize="14" Foreground="#ccc" TextAlignment="Center" />
					</Border>
					<Canvas x:Name="GameCanvas" Background="Transparent" ClipToBounds="True" 
							HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
				</DockPanel>
			</Border>

			<Border x:Name="CollectionPanel" Background="#0a0a1a" CornerRadius="15" IsVisible="{Binding IsCollectionActive}">
				<ScrollViewer>
					<ItemsControl x:Name="CollectionItems" ItemsSource="{Binding CapturedCreatures}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:CapturedCreature">
								<Border Background="#1a1a2e" CornerRadius="10" Padding="15" Margin="10" Width="200">
									<StackPanel>
										<views:AlienCatControl x:Name="CatControl" Width="80" Height="80" 
                       Color="{Binding Catalog.ColorHex}" 
                       IsHappy="True"
                       ShapeType="{Binding ShapeType}" />
										<TextBlock Text="{Binding Nickname}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Center" />
										<TextBlock Text="{Binding Catalog.Name}" FontSize="12" Foreground="#888" TextAlignment="Center" />
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
											<TextBlock Text="❤️ " Foreground="Pink" />
											<TextBlock Text="{Binding TimesHugged}" Foreground="White" />
										</StackPanel>
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
											<TextBlock Text="🍽️ " Foreground="Orange" />
											<TextBlock Text="{Binding TimesFed}" Foreground="White" />
										</StackPanel>
										<Grid Margin="0,5,0,0">
											<Rectangle Height="8" RadiusX="4" RadiusY="4" Fill="#333" />
											<Rectangle Height="8" RadiusX="4" RadiusY="4" Fill="LightGreen" Width="{Binding Hunger}" />
										</Grid>
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0" Spacing="5">
											<Button Content="🤗" Command="{Binding $parent[Window].DataContext.HugCommand}" CommandParameter="{Binding}" Width="35" Height="35" />
											<Button Content="🍎" Command="{Binding $parent[Window].DataContext.FeedCommand}" CommandParameter="{Binding}" Width="35" Height="35" />
											<Button Content="📖" Command="{Binding $parent[Window].DataContext.StoryCommand}" CommandParameter="{Binding}" Width="35" Height="35" />
											<Button Content="🕊️" Command="{Binding $parent[Window].DataContext.ReleaseCommand}" CommandParameter="{Binding}" Width="35" Height="35" Background="#e74c3c" Foreground="White" />
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Border>

			<Border x:Name="AlbumPanel" Background="#0a0a1a" CornerRadius="15" IsVisible="{Binding IsAlbumActive}">
				<DockPanel>
					<Border DockPanel.Dock="Bottom" Background="#1a1a2e" Padding="10" CornerRadius="10" Margin="0,10,0,0">
						<TextBlock Text="{Binding AlbumStatusText}" FontSize="14" Foreground="#ccc" TextAlignment="Center" />
					</Border>
					<ScrollViewer>
						<ItemsControl ItemsSource="{Binding AlbumItems}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="viewModels:AlbumItem">
									<Border Background="#1a1a2e" CornerRadius="15" Padding="15" Margin="10" BorderThickness="3" BorderBrush="{Binding RarityColor}">
										<StackPanel Width="140" HorizontalAlignment="Center">
											<views:AlienCatControl Width="80" Height="80" Color="{Binding DisplayColor}" IsHappy="{Binding IsCaptured}" />
											<TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="Bold" Foreground="{Binding DisplayForeground}" TextAlignment="Center" />
											<Border Background="{Binding RarityColor}" CornerRadius="5" Padding="5" Margin="0,5,0,0">
												<TextBlock Text="{Binding RarityName}" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
											</Border>
											<TextBlock Text="{Binding DisplayStatus}" FontSize="12" Foreground="#888" TextAlignment="Center" />
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</DockPanel>
			</Border>

			<!-- Экран игры "Поймай звезду" -->
			<Border x:Name="StarCatchPanel" Background="#0a0a1a" CornerRadius="15"
					IsVisible="{Binding IsStarCatchActive}">
				<DockPanel>
					<!-- Верхняя панель -->
					<Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="15" CornerRadius="0 0 15 15">
						<DockPanel>
							<TextBlock Text="🌟 Поймай звёзды!" FontSize="20" FontWeight="Bold" Foreground="Gold" />
							<StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="15">
								<TextBlock Text="✨ " Foreground="Gold" />
								<TextBlock x:Name="GameScoreText" Text="0" FontSize="18" Foreground="White" />
								<TextBlock Text="|" Foreground="#444" />
								<TextBlock Text="⏱️ " Foreground="White" />
								<TextBlock x:Name="GameTimerText" Text="30" FontSize="18" Foreground="White" />
							</StackPanel>
						</DockPanel>
					</Border>

					<!-- Игровое поле -->
					<Canvas x:Name="StarGameCanvas" Background="#0a0a1a" ClipToBounds="True" Width="800" Height="450" />

					<!-- Нижняя панель -->
					<Border DockPanel.Dock="Bottom" Background="#1a1a2e" Padding="10">
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
							<Button x:Name="GameStartButton" Content="▶️ Начать" Background="#4a6fa5" Foreground="White" Padding="15,8" />
							<Button Content="🏠 Выйти" Command="{Binding SwitchToGameCommand}" Background="#e74c3c" Foreground="White" Padding="15,8" />
						</StackPanel>
					</Border>
				</DockPanel>
			</Border>

			<!-- Экран игры "Мемори" -->
			<Border x:Name="MemoryPanel" Background="#0a0a1a" CornerRadius="15"
					IsVisible="{Binding IsMemoryActive}">
				<DockPanel>
					<!-- Верхняя панель -->
					<Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="15" CornerRadius="0 0 15 15">
						<DockPanel>
							<TextBlock Text="🧠 Найди пару!" FontSize="20" FontWeight="Bold" Foreground="Gold" />
							<StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="15">
								<TextBlock Text="Пары: " Foreground="White" />
								<TextBlock x:Name="MemoryPairsText" Text="0/16" FontSize="18" Foreground="White" />
								<TextBlock Text="|" Foreground="#444" />
								<TextBlock Text="Ходы: " Foreground="White" />
								<TextBlock x:Name="MemoryMovesText" Text="0" FontSize="18" Foreground="White" />
							</StackPanel>
						</DockPanel>
					</Border>

					<!-- Игровое поле -->
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
						<Grid x:Name="MemoryCardGrid" Margin="20"
							  Width="950" Height="550">
							<Grid.RowDefinitions>
								<RowDefinition />
								<RowDefinition />
								<RowDefinition />
								<RowDefinition />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition />
								<ColumnDefinition />
								<ColumnDefinition />
								<ColumnDefinition />
								<ColumnDefinition />
								<ColumnDefinition />
								<ColumnDefinition />
								<ColumnDefinition />
							</Grid.ColumnDefinitions>
						</Grid>
					</ScrollViewer>

					<!-- Нижняя панель -->
					<Border DockPanel.Dock="Bottom" Background="#1a1a2e" Padding="10">
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
							<Button x:Name="MemoryStartButton" Content="🔄 Новая игра" Background="#4a6fa5" Foreground="White" Padding="15,8" />
							<Button Content="🏠 Выйти" Command="{Binding SwitchToGameCommand}" Background="#e74c3c" Foreground="White" Padding="15,8" />
						</StackPanel>
					</Border>
				</DockPanel>
			</Border>
			
		</Grid>
	</DockPanel>
</Window>